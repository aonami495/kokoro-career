<div class="max-w-4xl mx-auto p-4 md:p-8">
  <% if notice %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-6">
      <%= notice %>
    </div>
  <% end %>
  <% if alert %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
      <%= alert %>
    </div>
  <% end %>

  <!-- ヘッダー -->
  <div class="bg-white rounded-lg shadow mb-6">
    <div class="p-6 border-b">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-3xl">🎓</span>
        <div>
          <h1 class="text-2xl font-bold">体験実習</h1>
          <p class="text-gray-600"><%= @job.title %> - <%= @company.company_name %></p>
        </div>
      </div>

      <div class="flex items-center justify-between">
        <span class="px-4 py-2 rounded-full text-sm font-medium <%= internship_status_class(@internship) %>">
          <%= internship_status_label(@internship) %>
        </span>
        <%= link_to "メッセージを見る", application_messages_path(@application),
            class: "text-teal-600 hover:text-teal-800" %>
      </div>
    </div>

    <!-- 実習情報 -->
    <div class="p-6 bg-gray-50">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div>
          <p class="text-sm text-gray-500">求職者</p>
          <p class="font-medium"><%= @job_seeker.user.name %> さん</p>
        </div>
        <div>
          <p class="text-sm text-gray-500">開始日</p>
          <p class="font-medium"><%= @internship.start_date.strftime("%Y/%m/%d") %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">終了日</p>
          <p class="font-medium"><%= @internship.end_date.strftime("%Y/%m/%d") %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">期間</p>
          <p class="font-medium"><%= @internship.duration_days %>日間</p>
        </div>
      </div>
    </div>

    <!-- 企業向け: ステータス変更ボタン -->
    <% if current_user.company? %>
      <div class="p-6 border-t">
        <h3 class="font-semibold mb-3">ステータス変更</h3>
        <div class="flex flex-wrap gap-3">
          <% if @internship.accepted? %>
            <%= button_to "実習を開始する",
                update_status_internship_path(@internship, status: "in_progress"),
                method: :patch,
                class: "bg-purple-600 text-white px-4 py-2 rounded-lg hover:bg-purple-700 font-medium cursor-pointer" %>
          <% elsif @internship.in_progress? %>
            <%= button_to "実習を終了する",
                update_status_internship_path(@internship, status: "completed"),
                method: :patch,
                class: "bg-gray-600 text-white px-4 py-2 rounded-lg hover:bg-gray-700 font-medium cursor-pointer" %>
          <% elsif @internship.completed? %>
            <%= button_to "本採用を決定する",
                update_status_internship_path(@internship, status: "hired"),
                method: :patch,
                data: { confirm: "本採用を決定しますか？" },
                class: "bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 font-medium cursor-pointer" %>
          <% elsif @internship.hired? %>
            <p class="text-green-600 font-medium">🎉 本採用が決定しました</p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- 日報セクション -->
  <div class="bg-white rounded-lg shadow">
    <div class="p-6 border-b">
      <h2 class="text-xl font-semibold">📝 日報・コメント</h2>
      <p class="text-sm text-gray-500 mt-1">実習中の記録や気づきを残しましょう</p>
    </div>

    <!-- 日報投稿フォーム -->
    <% if @internship.in_progress? || @internship.completed? %>
      <div class="p-6 bg-gray-50 border-b">
        <%= form_with model: DailyReport.new, url: internship_daily_reports_path(@internship), method: :post, local: true do |f| %>
          <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">日付</label>
            <%= f.date_field :report_date,
                value: Date.current,
                max: Date.current,
                min: @internship.start_date,
                class: "border border-gray-300 rounded-lg px-4 py-2 focus:ring-teal-500 focus:border-teal-500" %>
          </div>
          <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">内容</label>
            <%= f.text_area :content,
                rows: 4,
                class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-teal-500 focus:border-teal-500",
                placeholder: "今日の業務内容、学んだこと、気づいたことなどを記入してください..." %>
          </div>
          <%= f.submit "日報を投稿",
              class: "bg-teal-600 text-white px-6 py-2 rounded-lg hover:bg-teal-700 font-medium cursor-pointer" %>
        <% end %>
      </div>
    <% end %>

    <!-- 日報一覧 -->
    <div class="p-6">
      <% if @daily_reports.empty? %>
        <p class="text-center text-gray-500 py-8">まだ日報がありません</p>
      <% else %>
        <div class="space-y-6">
          <% @daily_reports.group_by(&:report_date).each do |date, reports| %>
            <div class="border-l-4 border-teal-500 pl-4">
              <h4 class="font-semibold text-gray-700 mb-3"><%= date.strftime("%Y年%m月%d日") %></h4>
              <div class="space-y-4">
                <% reports.each do |report| %>
                  <div class="bg-gray-50 rounded-lg p-4">
                    <div class="flex items-center justify-between mb-2">
                      <span class="font-medium text-gray-800">
                        <%= report.user.name %>
                        <span class="text-xs ml-2 px-2 py-1 rounded <%= report.author_type == :company ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700' %>">
                          <%= report.author_type == :company ? '企業' : '求職者' %>
                        </span>
                      </span>
                      <span class="text-xs text-gray-400"><%= report.created_at.strftime("%H:%M") %></span>
                    </div>
                    <p class="text-gray-700 whitespace-pre-wrap"><%= report.content %></p>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 戻るリンク -->
  <div class="mt-6 text-center">
    <% if current_user.job_seeker? %>
      <%= link_to "← マイページに戻る", job_seeker_dashboard_path, class: "text-gray-600 hover:text-teal-600" %>
    <% else %>
      <%= link_to "← ダッシュボードに戻る", company_dashboard_path, class: "text-gray-600 hover:text-teal-600" %>
    <% end %>
  </div>
</div>
