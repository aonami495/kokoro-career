<% content_for :page_title, "ダッシュボード" %>

<!-- 統計カード -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
  <!-- ユーザー統計 -->
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-500">総ユーザー数</p>
        <p class="text-3xl font-bold text-gray-800"><%= @total_users %></p>
      </div>
      <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center">
        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
        </svg>
      </div>
    </div>
    <div class="mt-4 flex gap-4 text-sm">
      <span class="text-gray-500">求職者: <span class="font-semibold text-gray-700"><%= @job_seekers_count %></span></span>
      <span class="text-gray-500">企業: <span class="font-semibold text-gray-700"><%= @companies_count %></span></span>
    </div>
  </div>

  <!-- 求人統計 -->
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-500">公開中の求人</p>
        <p class="text-3xl font-bold text-gray-800"><%= @published_jobs_count %></p>
      </div>
      <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
        <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
      </div>
    </div>
    <p class="mt-4 text-sm text-gray-500">総求人数: <span class="font-semibold text-gray-700"><%= @total_jobs_count %></span></p>
  </div>

  <!-- 応募統計 -->
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-500">マッチング成立</p>
        <p class="text-3xl font-bold text-gray-800"><%= @accepted_applications_count %></p>
      </div>
      <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center">
        <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
    </div>
    <div class="mt-4 flex gap-4 text-sm">
      <span class="text-gray-500">総応募: <span class="font-semibold text-gray-700"><%= @applications_count %></span></span>
      <span class="text-gray-500">本採用: <span class="font-semibold text-gray-700"><%= @hired_count %></span></span>
    </div>
  </div>

  <!-- 配慮タグ統計 -->
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-500">配慮タグ数</p>
        <p class="text-3xl font-bold text-gray-800"><%= @accommodation_tags.count %></p>
      </div>
      <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center">
        <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
        </svg>
      </div>
    </div>
    <%= link_to "管理する →", admin_accommodation_tags_path, class: "mt-4 inline-block text-sm text-orange-600 hover:text-orange-800" %>
  </div>
</div>

<!-- 配慮タグ一覧 -->
<div class="bg-white rounded-lg shadow">
  <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
    <h2 class="text-lg font-semibold text-gray-800">配慮タグ一覧</h2>
    <%= link_to new_admin_accommodation_tag_path, class: "bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 text-sm" do %>
      + 新規作成
    <% end %>
  </div>

  <div class="p-6">
    <% AccommodationTag::CATEGORIES.each do |category| %>
      <% tags = @tags_by_category[category] || [] %>
      <div class="mb-6 last:mb-0">
        <h3 class="font-semibold text-gray-700 mb-3 flex items-center gap-2">
          <span class="px-2 py-1 text-xs rounded-full
            <%= case category
                when 'environment' then 'bg-blue-100 text-blue-700'
                when 'communication' then 'bg-green-100 text-green-700'
                when 'schedule' then 'bg-purple-100 text-purple-700'
                when 'support' then 'bg-orange-100 text-orange-700'
                else 'bg-gray-100 text-gray-700'
                end %>">
            <%= AccommodationTag.category_label(category) %>
          </span>
          <span class="text-sm text-gray-500">(<%= tags.count %>件)</span>
        </h3>

        <div class="flex flex-wrap gap-2">
          <% tags.each do |tag| %>
            <%= link_to edit_admin_accommodation_tag_path(tag),
                class: "inline-flex items-center gap-1 px-3 py-1 bg-gray-100 hover:bg-gray-200 rounded-full text-sm text-gray-700 transition" do %>
              <%= tag.name %>
              <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
              </svg>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
