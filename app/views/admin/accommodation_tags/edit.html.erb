<% content_for :page_title, "配慮タグを編集" %>

<div class="max-w-2xl">
  <div class="bg-white rounded-lg shadow p-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-6">
      「<%= @accommodation_tag.name %>」を編集
    </h2>
    <%= render "form", accommodation_tag: @accommodation_tag %>
  </div>

  <div class="mt-6 p-4 bg-red-50 rounded-lg border border-red-200">
    <h3 class="font-medium text-red-800 mb-2">危険な操作</h3>
    <p class="text-sm text-red-600 mb-3">
      このタグを削除すると、このタグを使用しているすべてのユーザーの設定からも削除されます。
    </p>
    <%= button_to "このタグを削除", admin_accommodation_tag_path(@accommodation_tag),
        method: :delete,
        data: { turbo_confirm: "「#{@accommodation_tag.name}」を本当に削除しますか？\n\n※このタグを使用しているユーザーの設定にも影響します。この操作は取り消せません。" },
        class: "bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 text-sm" %>
  </div>
</div>
