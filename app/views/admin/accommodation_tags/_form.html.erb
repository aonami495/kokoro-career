<%= form_with model: [:admin, accommodation_tag], local: true, class: "space-y-6" do |f| %>
  <% if accommodation_tag.errors.any? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
      <h3 class="font-bold mb-2">入力エラーがあります</h3>
      <ul class="list-disc list-inside">
        <% accommodation_tag.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "タグ名", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name,
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500",
        placeholder: "例: 在宅勤務可（週3日以上）" %>
  </div>

  <div>
    <%= f.label :category, "カテゴリ", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :category,
        AccommodationTag::CATEGORIES.map { |c| [AccommodationTag.category_label(c), c] },
        { include_blank: "選択してください" },
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500" %>
    <p class="mt-1 text-sm text-gray-500">
      environment: 作業環境 / communication: コミュニケーション / schedule: 勤務時間 / support: サポート体制
    </p>
  </div>

  <div>
    <%= f.label :description, "説明", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 3,
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500",
        placeholder: "このタグの詳細な説明を入力してください" %>
  </div>

  <div>
    <%= f.label :display_order, "表示順序", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.number_field :display_order,
        class: "w-32 px-4 py-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500",
        min: 0 %>
    <p class="mt-1 text-sm text-gray-500">数字が小さいほど先に表示されます</p>
  </div>

  <div class="flex gap-4 pt-4 border-t">
    <%= f.submit accommodation_tag.persisted? ? "更新する" : "作成する",
        class: "bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "キャンセル", admin_accommodation_tags_path,
        class: "bg-gray-200 text-gray-700 px-6 py-2 rounded-lg hover:bg-gray-300" %>
  </div>
<% end %>
