<% content_for :page_title, "配慮タグ管理" %>

<div class="mb-6 flex justify-between items-center">
  <p class="text-gray-600">配慮タグの追加・編集・削除ができます。</p>
  <%= link_to new_admin_accommodation_tag_path, class: "bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 flex items-center gap-2" do %>
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
    </svg>
    新規タグを作成
  <% end %>
</div>

<% AccommodationTag::CATEGORIES.each do |category| %>
  <% tags = @tags_by_category[category] || [] %>
  <div class="bg-white rounded-lg shadow mb-6">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center gap-3">
      <span class="px-3 py-1 text-sm font-medium rounded-full
        <%= case category
            when 'environment' then 'bg-blue-100 text-blue-700'
            when 'communication' then 'bg-green-100 text-green-700'
            when 'schedule' then 'bg-purple-100 text-purple-700'
            when 'support' then 'bg-orange-100 text-orange-700'
            else 'bg-gray-100 text-gray-700'
            end %>">
        <%= AccommodationTag.category_label(category) %>
      </span>
      <span class="text-sm text-gray-500"><%= tags.count %>件</span>
    </div>

    <% if tags.any? %>
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">順序</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">タグ名</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">説明</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% tags.each do |tag| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= tag.display_order %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="font-medium text-gray-900"><%= tag.name %></span>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500">
                <%= truncate(tag.description, length: 50) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                <%= link_to "編集", edit_admin_accommodation_tag_path(tag),
                    class: "text-indigo-600 hover:text-indigo-900 mr-4" %>
                <%= button_to "削除", admin_accommodation_tag_path(tag),
                    method: :delete,
                    data: { turbo_confirm: "「#{tag.name}」を削除しますか？\n※このタグを使用しているユーザーの設定にも影響します。" },
                    class: "text-red-600 hover:text-red-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="px-6 py-8 text-center text-gray-500">このカテゴリにはまだタグがありません</p>
    <% end %>
  </div>
<% end %>
