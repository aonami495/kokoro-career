<% content_for :page_title, "ユーザー管理" %>

<div class="mb-6">
  <p class="text-gray-600">登録されている全ユーザーを管理できます。</p>
</div>

<!-- 統計 -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-lg shadow p-4">
    <p class="text-sm text-gray-500">総ユーザー数</p>
    <p class="text-2xl font-bold text-gray-800"><%= User.count %></p>
  </div>
  <div class="bg-white rounded-lg shadow p-4">
    <p class="text-sm text-gray-500">求職者</p>
    <p class="text-2xl font-bold text-blue-600"><%= User.job_seeker.count %></p>
  </div>
  <div class="bg-white rounded-lg shadow p-4">
    <p class="text-sm text-gray-500">企業</p>
    <p class="text-2xl font-bold text-green-600"><%= User.company.count %></p>
  </div>
  <div class="bg-white rounded-lg shadow p-4">
    <p class="text-sm text-gray-500">管理者</p>
    <p class="text-2xl font-bold text-purple-600"><%= User.admin.count %></p>
  </div>
</div>

<!-- ユーザー一覧 -->
<div class="bg-white rounded-lg shadow">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-800">ユーザー一覧</h2>
  </div>

  <table class="w-full">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">名前</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">メールアドレス</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">タイプ</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">登録日</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">操作</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @users.each do |user| %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= user.id %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="flex items-center">
              <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-sm font-bold
                <%= case user.user_type
                    when 'job_seeker' then 'bg-blue-500'
                    when 'company' then 'bg-green-500'
                    when 'admin' then 'bg-purple-500'
                    else 'bg-gray-500'
                    end %>">
                <%= user.name.first %>
              </div>
              <span class="ml-3 font-medium text-gray-900"><%= user.name %></span>
            </div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= user.email %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="px-2 py-1 text-xs font-medium rounded-full
              <%= case user.user_type
                  when 'job_seeker' then 'bg-blue-100 text-blue-700'
                  when 'company' then 'bg-green-100 text-green-700'
                  when 'admin' then 'bg-purple-100 text-purple-700'
                  else 'bg-gray-100 text-gray-700'
                  end %>">
              <%= case user.user_type
                  when 'job_seeker' then '求職者'
                  when 'company' then '企業'
                  when 'admin' then '管理者'
                  else user.user_type
                  end %>
            </span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= user.created_at.strftime("%Y/%m/%d") %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
            <% if user.admin? %>
              <span class="text-gray-400">削除不可</span>
            <% else %>
              <%= button_to "削除", admin_user_path(user),
                  method: :delete,
                  data: { turbo_confirm: "「#{user.name}」を削除しますか？\n\n※このユーザーに関連するデータもすべて削除されます。" },
                  class: "text-red-600 hover:text-red-900" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if @users.empty? %>
    <p class="px-6 py-8 text-center text-gray-500">ユーザーがいません</p>
  <% end %>
</div>
