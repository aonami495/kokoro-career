<% content_for :page_title, "通報管理" %>

<div class="mb-6">
  <p class="text-gray-600">ユーザーからの通報を確認し、対応してください。</p>
</div>

<!-- 統計 -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
  <div class="bg-white rounded-lg shadow p-4">
    <p class="text-sm text-gray-500">未対応</p>
    <p class="text-2xl font-bold text-red-600"><%= Report.pending.count %></p>
  </div>
  <div class="bg-white rounded-lg shadow p-4">
    <p class="text-sm text-gray-500">対応済み</p>
    <p class="text-2xl font-bold text-green-600"><%= Report.resolved.count %></p>
  </div>
  <div class="bg-white rounded-lg shadow p-4">
    <p class="text-sm text-gray-500">却下</p>
    <p class="text-2xl font-bold text-gray-600"><%= Report.ignored.count %></p>
  </div>
</div>

<!-- 未対応の通報 -->
<% if @pending_reports.any? %>
  <div class="bg-white rounded-lg shadow mb-6">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center gap-2">
      <span class="w-3 h-3 bg-red-500 rounded-full animate-pulse"></span>
      <h2 class="text-lg font-semibold text-gray-800">未対応の通報 (<%= @pending_reports.count %>件)</h2>
    </div>

    <div class="divide-y divide-gray-200">
      <% @pending_reports.each do |report| %>
        <%= render "report_row", report: report %>
      <% end %>
    </div>
  </div>
<% end %>

<!-- 対応済み・却下の通報 -->
<div class="bg-white rounded-lg shadow">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-800">対応履歴</h2>
  </div>

  <% if @resolved_reports.any? %>
    <div class="divide-y divide-gray-200">
      <% @resolved_reports.each do |report| %>
        <%= render "report_row", report: report %>
      <% end %>
    </div>
  <% else %>
    <p class="px-6 py-8 text-center text-gray-500">対応履歴がありません</p>
  <% end %>
</div>
