<div class="min-h-[calc(100vh-4rem)] flex items-center justify-center bg-gradient-to-br from-teal-50 to-slate-100 py-12 px-4">
  <div class="w-full max-w-md">
    <!-- ブランディング -->
    <div class="text-center mb-8">
      <span class="text-4xl">🤝</span>
      <h1 class="mt-2 text-2xl font-bold text-slate-800">ココロキャリア</h1>
      <p class="mt-1 text-sm text-slate-500">配慮の可視化で、安心できるマッチングを。</p>
    </div>

    <!-- ログインカード -->
    <div class="bg-white rounded-2xl shadow-lg p-8">
      <h2 class="text-xl font-bold text-slate-800 text-center mb-6">ログイン</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
        <div>
          <%= f.label :email, "メールアドレス", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              placeholder: "example@email.com",
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500 transition duration-150" %>
        </div>

        <div data-controller="password-visibility">
          <%= f.label :password, "パスワード", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <div class="relative">
            <%= f.password_field :password,
                autocomplete: "current-password",
                data: { password_visibility_target: "input" },
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500 transition duration-150 pr-12" %>
            <button type="button"
                    data-action="password-visibility#toggle"
                    data-password-visibility-target="button"
                    class="absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400 hover:text-slate-600"
                    aria-label="パスワードを表示">
              <!-- 非表示アイコン (eye) -->
              <svg data-password-visibility-target="iconShow" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              <!-- 表示アイコン (eye-off) -->
              <svg data-password-visibility-target="iconHide" class="h-5 w-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
              </svg>
            </button>
          </div>
        </div>

        <div class="flex items-center justify-between">
          <% if devise_mapping.rememberable? %>
            <label class="inline-flex items-center">
              <%= f.check_box :remember_me, class: "h-4 w-4 text-teal-600 focus:ring-teal-500 border-gray-300 rounded" %>
              <span class="ml-2 text-sm text-slate-600">ログイン状態を保持</span>
            </label>
          <% end %>

          <% if devise_mapping.recoverable? %>
            <%= link_to "パスワードをお忘れですか？", new_password_path(resource_name),
                class: "text-sm text-teal-600 hover:text-teal-700 font-medium" %>
          <% end %>
        </div>

        <div>
          <%= f.submit "ログイン", class: "w-full py-3 px-4 border border-transparent rounded-lg shadow-sm text-base font-medium text-white bg-teal-600 hover:bg-teal-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-500 cursor-pointer transition duration-150" %>
        </div>
      <% end %>
    </div>

    <!-- 新規登録への誘導 -->
    <div class="mt-6 text-center">
      <p class="text-sm text-slate-600">
        アカウントをお持ちでない方は
        <%= link_to "新規登録", new_registration_path(resource_name),
            class: "text-teal-600 hover:text-teal-700 font-semibold" %>
      </p>
    </div>
  </div>
</div>
