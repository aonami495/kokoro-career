<div class="min-h-[calc(100vh-4rem)] flex items-center justify-center bg-gradient-to-br from-teal-50 to-slate-100 py-12 px-4">
  <div class="w-full max-w-md">
    <!-- ブランディング -->
    <div class="text-center mb-8">
      <span class="text-4xl">🤝</span>
      <h1 class="mt-2 text-2xl font-bold text-slate-800">ココロキャリア</h1>
      <p class="mt-1 text-sm text-slate-500">配慮の可視化で、安心できるマッチングを。</p>
    </div>

    <!-- パスワード変更カード -->
    <div class="bg-white rounded-2xl shadow-lg p-8">
      <div class="text-center mb-6">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-teal-100 mb-4">
          <svg class="w-7 h-7 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
          </svg>
        </div>
        <h2 class="text-xl font-bold text-slate-800">新しいパスワードを設定</h2>
        <p class="mt-2 text-sm text-slate-500">安全なパスワードを設定してください。</p>
      </div>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <div data-controller="password-visibility">
          <%= f.label :password, "新しいパスワード", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <% if @minimum_password_length %>
            <p class="text-xs text-slate-500 mb-1"><%= @minimum_password_length %>文字以上で設定してください</p>
          <% end %>
          <div class="relative">
            <%= f.password_field :password,
                autofocus: true,
                autocomplete: "new-password",
                placeholder: "新しいパスワードを入力",
                data: { password_visibility_target: "input" },
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500 transition duration-150 pr-12" %>
            <button type="button"
                    data-action="password-visibility#toggle"
                    data-password-visibility-target="button"
                    class="absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400 hover:text-slate-600"
                    aria-label="パスワードを表示">
              <svg data-password-visibility-target="iconShow" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              <svg data-password-visibility-target="iconHide" class="h-5 w-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
              </svg>
            </button>
          </div>
        </div>

        <div>
          <%= f.label :password_confirmation, "新しいパスワード（確認）", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              placeholder: "もう一度パスワードを入力",
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500 transition duration-150" %>
        </div>

        <!-- パスワード強度の目安 -->
        <div class="bg-slate-50 rounded-lg p-4">
          <p class="text-xs font-medium text-slate-700 mb-2">安全なパスワードのポイント:</p>
          <ul class="text-xs text-slate-600 space-y-1">
            <li class="flex items-center">
              <svg class="w-4 h-4 mr-2 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              英大文字・小文字を含める
            </li>
            <li class="flex items-center">
              <svg class="w-4 h-4 mr-2 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              数字を含める
            </li>
            <li class="flex items-center">
              <svg class="w-4 h-4 mr-2 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              他のサービスと異なるパスワードを使用
            </li>
          </ul>
        </div>

        <div>
          <%= f.submit "パスワードを変更", class: "w-full py-3 px-4 border border-transparent rounded-lg shadow-sm text-base font-medium text-white bg-teal-600 hover:bg-teal-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-500 cursor-pointer transition duration-150" %>
        </div>
      <% end %>
    </div>

    <!-- ナビゲーションリンク -->
    <div class="mt-6 text-center">
      <%= link_to "ログインに戻る", new_session_path(resource_name),
          class: "text-sm text-teal-600 hover:text-teal-700 font-semibold" %>
    </div>
  </div>
</div>
