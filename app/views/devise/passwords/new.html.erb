<div class="min-h-[calc(100vh-4rem)] flex items-center justify-center bg-gradient-to-br from-teal-50 to-slate-100 py-12 px-4">
  <div class="w-full max-w-md">
    <!-- ブランディング -->
    <div class="text-center mb-8">
      <span class="text-4xl">🤝</span>
      <h1 class="mt-2 text-2xl font-bold text-slate-800">ココロキャリア</h1>
      <p class="mt-1 text-sm text-slate-500">配慮の可視化で、安心できるマッチングを。</p>
    </div>

    <!-- パスワードリセットカード -->
    <div class="bg-white rounded-2xl shadow-lg p-8">
      <div class="text-center mb-6">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-teal-100 mb-4">
          <svg class="w-7 h-7 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
          </svg>
        </div>
        <h2 class="text-xl font-bold text-slate-800">パスワードをお忘れですか？</h2>
        <p class="mt-2 text-sm text-slate-500">
          ご登録のメールアドレスを入力してください。<br>
          パスワード再設定用のリンクをお送りします。
        </p>
      </div>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, "メールアドレス", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              placeholder: "example@email.com",
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500 transition duration-150" %>
        </div>

        <div>
          <%= f.submit "再設定メールを送信", class: "w-full py-3 px-4 border border-transparent rounded-lg shadow-sm text-base font-medium text-white bg-teal-600 hover:bg-teal-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-500 cursor-pointer transition duration-150" %>
        </div>
      <% end %>
    </div>

    <!-- ナビゲーションリンク -->
    <div class="mt-6 text-center space-y-2">
      <p class="text-sm text-slate-600">
        <%= link_to "ログインに戻る", new_session_path(resource_name),
            class: "text-teal-600 hover:text-teal-700 font-semibold" %>
      </p>
      <p class="text-sm text-slate-600">
        アカウントをお持ちでない方は
        <%= link_to "新規登録", new_registration_path(resource_name),
            class: "text-teal-600 hover:text-teal-700 font-semibold" %>
      </p>
    </div>
  </div>
</div>
