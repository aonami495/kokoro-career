<div class="max-w-3xl mx-auto p-4 md:p-8">
  <!-- ヘッダー -->
  <div class="bg-white rounded-lg shadow mb-4">
    <div class="p-4 border-b">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-xl font-bold text-gray-900">
            <% if current_user.job_seeker? %>
              <%= @company.company_name %> とのやり取り
            <% else %>
              <%= @job_seeker.user.name %> さんとのやり取り
            <% end %>
          </h1>
          <p class="text-sm text-gray-500 mt-1">
            求人: <%= @job.title %>
          </p>
        </div>
        <div class="text-right">
          <span class="px-3 py-1 rounded-full text-sm font-medium <%= application_status_class(@application) %>">
            <%= application_status_label(@application) %>
          </span>
        </div>
      </div>
    </div>

    <!-- 応募情報 -->
    <div class="p-4 bg-gray-50 text-sm">
      <div class="flex flex-wrap gap-4">
        <div>
          <span class="text-gray-500">応募日:</span>
          <span class="font-medium"><%= @application.created_at.strftime("%Y/%m/%d") %></span>
        </div>
        <% if current_user.company? %>
          <div>
            <span class="text-gray-500">マッチ度:</span>
            <span class="font-medium text-teal-600"><%= @company.match_score(@job_seeker) %>%</span>
          </div>
        <% end %>
      </div>
      <% if @application.message.present? %>
        <div class="mt-2 p-3 bg-white rounded border">
          <p class="text-xs text-gray-500 mb-1">応募時メッセージ:</p>
          <p class="text-gray-700"><%= @application.message %></p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 実習オファー情報 -->
  <% if @application.internship.present? %>
    <% internship = @application.internship %>
    <div class="bg-orange-50 border border-orange-200 rounded-lg shadow mb-4 p-4">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-2xl">🎓</span>
        <h2 class="text-lg font-semibold text-orange-800">体験実習オファー</h2>
        <span class="px-2 py-1 rounded text-xs font-medium <%= internship_status_class(internship) %>">
          <%= internship_status_label(internship) %>
        </span>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 text-sm mb-4">
        <div>
          <p class="text-gray-500">開始日</p>
          <p class="font-medium"><%= internship.start_date.strftime("%Y/%m/%d") %></p>
        </div>
        <div>
          <p class="text-gray-500">終了日</p>
          <p class="font-medium"><%= internship.end_date.strftime("%Y/%m/%d") %></p>
        </div>
        <div>
          <p class="text-gray-500">期間</p>
          <p class="font-medium"><%= internship.duration_days %>日間（約<%= internship.duration_weeks %>週間）</p>
        </div>
      </div>

      <% if current_user.job_seeker? && internship.pending? %>
        <div class="flex gap-3 pt-3 border-t border-orange-200">
          <%= button_to "承諾する",
              application_internship_path(@application, response: "accept"),
              method: :patch,
              class: "bg-teal-600 text-white px-6 py-2 rounded-lg hover:bg-teal-700 font-medium cursor-pointer" %>
          <%= button_to "辞退する",
              application_internship_path(@application, response: "decline"),
              method: :patch,
              data: { confirm: "本当に辞退しますか？" },
              class: "bg-gray-500 text-white px-6 py-2 rounded-lg hover:bg-gray-600 font-medium cursor-pointer" %>
        </div>
      <% end %>
    </div>
  <% elsif current_user.company? && @job.internship_available? %>
    <!-- 企業向け: 実習オファー送信フォーム -->
    <div class="bg-white rounded-lg shadow mb-4 p-4">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-2xl">🎓</span>
        <h2 class="text-lg font-semibold">体験実習オファーを送る</h2>
      </div>

      <%= form_with model: Internship.new, url: application_internship_path(@application), method: :post, local: true do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">開始日</label>
            <%= f.date_field :start_date,
                min: Date.tomorrow,
                class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-teal-500 focus:border-teal-500",
                required: true %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">終了日</label>
            <%= f.date_field :end_date,
                min: Date.tomorrow,
                class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-teal-500 focus:border-teal-500",
                required: true %>
          </div>
        </div>
        <p class="text-sm text-gray-500 mb-4">※ 1〜2週間の実習期間を推奨しています</p>
        <%= f.submit "実習オファーを送信",
            class: "bg-orange-500 text-white px-6 py-2 rounded-lg hover:bg-orange-600 font-medium cursor-pointer" %>
      <% end %>
    </div>
  <% end %>

  <!-- メッセージ一覧 -->
  <div class="bg-white rounded-lg shadow mb-4">
    <div class="p-4 h-96 overflow-y-auto" id="message-container">
      <% if @messages.empty? %>
        <div class="text-center text-gray-500 py-12">
          <p>まだメッセージはありません</p>
          <p class="text-sm mt-2">下のフォームからメッセージを送信してください</p>
        </div>
      <% else %>
        <div class="space-y-4">
          <% @messages.each do |message| %>
            <% is_mine = message.sender == current_user %>
            <div class="flex <%= is_mine ? 'justify-end' : 'justify-start' %>">
              <div class="max-w-xs md:max-w-md">
                <% unless is_mine %>
                  <p class="text-xs text-gray-500 mb-1 ml-1">
                    <%= message.sender.name %>
                  </p>
                <% end %>
                <div class="<%= is_mine ? 'bg-teal-600 text-white' : 'bg-gray-100 text-gray-800' %> rounded-lg px-4 py-2">
                  <p class="whitespace-pre-wrap"><%= message.content %></p>
                </div>
                <p class="text-xs text-gray-400 mt-1 <%= is_mine ? 'text-right mr-1' : 'ml-1' %>">
                  <%= message.created_at.strftime("%m/%d %H:%M") %>
                  <% if is_mine && message.read_at.present? %>
                    <span class="ml-1">既読</span>
                  <% end %>
                </p>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- メッセージ送信フォーム -->
  <div class="bg-white rounded-lg shadow p-4">
    <%= form_with model: Message.new, url: application_messages_path(@application), method: :post, local: true, class: "flex gap-3" do |f| %>
      <div class="flex-1">
        <%= f.text_area :content,
            rows: 2,
            class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-teal-500 focus:border-teal-500 resize-none",
            placeholder: "メッセージを入力..." %>
      </div>
      <div class="flex items-end">
        <%= f.submit "送信",
            class: "bg-teal-600 text-white px-6 py-2 rounded-lg hover:bg-teal-700 font-medium cursor-pointer h-10" %>
      </div>
    <% end %>
  </div>

  <!-- 戻るリンク -->
  <div class="mt-6 text-center">
    <% if current_user.job_seeker? %>
      <%= link_to "← マイページに戻る", job_seeker_dashboard_path, class: "text-gray-600 hover:text-teal-600" %>
    <% else %>
      <%= link_to "← ダッシュボードに戻る", company_dashboard_path, class: "text-gray-600 hover:text-teal-600" %>
    <% end %>
  </div>
</div>

<script>
  // メッセージコンテナを最下部にスクロール
  document.addEventListener('DOMContentLoaded', function() {
    const container = document.getElementById('message-container');
    if (container) {
      container.scrollTop = container.scrollHeight;
    }
  });
</script>
