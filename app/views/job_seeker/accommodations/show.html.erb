<div class="max-w-4xl mx-auto p-8">
  <% if notice %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-6">
      <%= notice %>
    </div>
  <% end %>

  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold">あなたが登録した配慮</h1>
    <%= link_to "編集する", edit_job_seeker_accommodations_path,
        class: "text-teal-600 hover:underline font-semibold" %>
  </div>

  <% if @required_tags.empty? && @preferred_tags.empty? %>
    <div class="bg-gray-50 rounded-lg p-8 text-center">
      <p class="text-gray-600 mb-4">まだ配慮タグが登録されていません。</p>
      <%= link_to "配慮タグを登録する", new_job_seeker_accommodations_path,
          class: "bg-teal-600 text-white px-6 py-2 rounded-lg hover:bg-teal-700 inline-block" %>
    </div>
  <% else %>
    <div class="space-y-6">
      <% if @required_tags.any? %>
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-xl font-semibold text-red-600 mb-4 flex items-center gap-2">
            <span class="bg-red-100 text-red-600 px-2 py-1 rounded text-sm">必須</span>
            絶対に必要な配慮
          </h2>
          <div class="flex flex-wrap gap-2">
            <% @required_tags.each do |tag| %>
              <span class="bg-red-50 text-red-800 border border-red-200 px-4 py-2 rounded-full text-sm font-medium">
                <%= tag.name %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @preferred_tags.any? %>
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-xl font-semibold text-blue-600 mb-4 flex items-center gap-2">
            <span class="bg-blue-100 text-blue-600 px-2 py-1 rounded text-sm">希望</span>
            あると嬉しい配慮
          </h2>
          <div class="flex flex-wrap gap-2">
            <% @preferred_tags.each do |tag| %>
              <span class="bg-blue-50 text-blue-800 border border-blue-200 px-4 py-2 rounded-full text-sm font-medium">
                <%= tag.name %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-8 p-4 bg-gray-50 rounded-lg">
      <p class="text-sm text-gray-600">
        <strong>登録数:</strong>
        必須 <%= @required_tags.size %>件 / 希望 <%= @preferred_tags.size %>件
        （合計 <%= @required_tags.size + @preferred_tags.size %>件）
      </p>
    </div>
  <% end %>
</div>
