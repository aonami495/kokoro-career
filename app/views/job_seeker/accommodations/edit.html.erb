<div class="max-w-4xl mx-auto p-8">
  <h1 class="text-3xl font-bold mb-4">配慮タグを編集</h1>
  <p class="text-gray-600 mb-8">
    必要な配慮を変更できます。<br>
    <strong class="text-red-600">「必須」</strong>は絶対に必要な配慮、
    <strong class="text-blue-600">「あると嬉しい」</strong>は希望する配慮です。
  </p>

  <%= form_with url: job_seeker_accommodations_path, method: :patch, local: true do |f| %>
    <% @tags_by_category.each do |category, tags| %>
      <div class="mb-8">
        <h2 class="text-2xl font-semibold mb-4 border-b pb-2 flex items-center gap-2">
          <span><%= category_icon(category) %></span>
          <span><%= category_name(category) %></span>
          <span class="text-sm font-normal text-gray-500">(<%= tags.size %>項目)</span>
        </h2>

        <div class="space-y-3">
          <% tags.each do |tag| %>
            <% selected = @selected_accommodations[tag.id] %>
            <% current_priority = selected&.priority %>
            <div class="flex flex-col sm:flex-row sm:items-center p-4 bg-white rounded-lg shadow border border-gray-100">
              <div class="flex-1 mb-3 sm:mb-0">
                <label class="font-medium text-gray-800"><%= tag.name %></label>
                <p class="text-sm text-gray-500"><%= tag.description %></p>
              </div>
              <div class="flex space-x-4">
                <label class="flex items-center cursor-pointer">
                  <%= radio_button_tag "accommodations[#{tag.id}]", "required", current_priority == "required",
                      class: "mr-2 text-red-600 focus:ring-red-500" %>
                  <span class="text-red-600 font-semibold text-sm">必須</span>
                </label>
                <label class="flex items-center cursor-pointer">
                  <%= radio_button_tag "accommodations[#{tag.id}]", "preferred", current_priority == "preferred",
                      class: "mr-2 text-blue-600 focus:ring-blue-500" %>
                  <span class="text-blue-600 font-semibold text-sm">あると嬉しい</span>
                </label>
                <label class="flex items-center cursor-pointer">
                  <%= radio_button_tag "accommodations[#{tag.id}]", "none", current_priority.nil?,
                      class: "mr-2 text-gray-400 focus:ring-gray-400" %>
                  <span class="text-gray-400 text-sm">選択しない</span>
                </label>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="flex justify-between mt-8 sticky bottom-4">
      <%= link_to "キャンセル", job_seeker_accommodations_path,
          class: "bg-gray-200 text-gray-700 px-6 py-3 rounded-lg hover:bg-gray-300 text-lg font-semibold" %>
      <%= f.submit "変更を保存する",
          class: "bg-teal-600 text-white px-8 py-3 rounded-lg hover:bg-teal-700 text-lg font-semibold shadow-lg cursor-pointer" %>
    </div>
  <% end %>
</div>
