<div class="max-w-4xl mx-auto p-8">

  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold">提供可能な配慮</h1>
    <%= link_to "編集する", edit_company_accommodations_path,
        class: "bg-teal-600 text-white px-4 py-2 rounded-lg hover:bg-teal-700 font-semibold" %>
  </div>

  <% if @accommodations.empty? %>
    <div class="bg-gray-50 rounded-lg p-8 text-center">
      <p class="text-gray-600 mb-4">まだ配慮タグが登録されていません。</p>
      <p class="text-sm text-gray-500 mb-4">提供できる配慮を登録すると、求職者とのマッチング精度が向上します。</p>
      <%= link_to "配慮タグを登録する", edit_company_accommodations_path,
          class: "bg-teal-600 text-white px-6 py-2 rounded-lg hover:bg-teal-700 inline-block" %>
    </div>
  <% else %>
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-gray-600 mb-4">
        <strong><%= @accommodations.size %>件</strong>の配慮を提供可能として登録しています。
      </p>

      <% @accommodations.group_by { |a| a.accommodation_tag.category }.each do |category, accommodations| %>
        <div class="mb-6">
          <h2 class="text-lg font-semibold text-teal-700 mb-3 flex items-center gap-2">
            <span><%= category_icon(category) %></span>
            <span><%= category_name(category) %></span>
          </h2>
          <div class="space-y-2">
            <% accommodations.each do |accommodation| %>
              <div class="flex items-start p-3 bg-teal-50 rounded-lg border border-teal-100">
                <span class="text-teal-600 mr-2">✓</span>
                <div class="flex-1">
                  <span class="font-medium text-gray-800"><%= accommodation.accommodation_tag.name %></span>
                  <% if accommodation.detail_description.present? %>
                    <p class="text-sm text-gray-600 mt-1"><%= accommodation.detail_description %></p>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="mt-8">
    <%= link_to "← ダッシュボードに戻る", company_dashboard_path,
        class: "text-gray-600 hover:text-gray-800" %>
  </div>
</div>
