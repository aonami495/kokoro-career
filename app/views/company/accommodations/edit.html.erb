<div class="max-w-4xl mx-auto p-8">
  <h1 class="text-3xl font-bold mb-4">提供可能な配慮を設定</h1>
  <p class="text-gray-600 mb-8">
    貴社で提供できる配慮にチェックを入れてください。<br>
    補足説明を追加すると、求職者により詳しい情報を伝えられます。
  </p>

  <%= form_with url: company_accommodations_path, method: :patch, local: true do |f| %>
    <% @tags_by_category.each do |category, tags| %>
      <div class="mb-8">
        <h2 class="text-2xl font-semibold mb-4 border-b pb-2 flex items-center gap-2">
          <span><%= category_icon(category) %></span>
          <span><%= category_name(category) %></span>
          <span class="text-sm font-normal text-gray-500">(<%= tags.size %>項目)</span>
        </h2>

        <div class="space-y-4">
          <% tags.each do |tag| %>
            <% selected = @selected_accommodations[tag.id] %>
            <div class="p-4 bg-white rounded-lg shadow border border-gray-100">
              <div class="flex items-start">
                <label class="flex items-start cursor-pointer flex-1">
                  <%= check_box_tag "accommodations[#{tag.id}][selected]", "1", selected.present?,
                      class: "mt-1 mr-3 text-teal-600 focus:ring-teal-500 h-5 w-5",
                      data: { toggle_detail: tag.id } %>
                  <div class="flex-1">
                    <span class="font-medium text-gray-800"><%= tag.name %></span>
                    <p class="text-sm text-gray-500"><%= tag.description %></p>
                  </div>
                </label>
              </div>

              <div class="mt-3 ml-8" id="detail_<%= tag.id %>" style="<%= 'display: none;' unless selected.present? %>">
                <label class="block text-sm font-medium text-gray-700 mb-1">補足説明（任意）</label>
                <%= text_field_tag "accommodations[#{tag.id}][detail_description]",
                    selected&.detail_description,
                    class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-teal-500 focus:border-teal-500 text-sm",
                    placeholder: "例: 防音個室を3部屋用意しています" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="flex justify-between mt-8 sticky bottom-4">
      <%= link_to "キャンセル", company_accommodations_path,
          class: "bg-gray-200 text-gray-700 px-6 py-3 rounded-lg hover:bg-gray-300 text-lg font-semibold" %>
      <%= f.submit "この内容で保存する",
          class: "bg-teal-600 text-white px-8 py-3 rounded-lg hover:bg-teal-700 text-lg font-semibold shadow-lg cursor-pointer" %>
    </div>
  <% end %>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('[data-toggle-detail]').forEach(function(checkbox) {
    checkbox.addEventListener('change', function() {
      const detailDiv = document.getElementById('detail_' + this.dataset.toggleDetail);
      if (this.checked) {
        detailDiv.style.display = 'block';
      } else {
        detailDiv.style.display = 'none';
      }
    });
  });
});
</script>
