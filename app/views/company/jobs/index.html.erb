<div class="max-w-4xl mx-auto p-8">

  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold">求人管理</h1>
    <%= link_to "新規求人を作成", new_company_job_path,
        class: "bg-teal-600 text-white px-4 py-2 rounded-lg hover:bg-teal-700 font-semibold" %>
  </div>

  <% if @jobs.empty? %>
    <div class="bg-gray-50 rounded-lg p-8 text-center">
      <p class="text-gray-600 mb-4">まだ求人が登録されていません。</p>
      <%= link_to "最初の求人を作成する", new_company_job_path,
          class: "bg-teal-600 text-white px-6 py-2 rounded-lg hover:bg-teal-700 inline-block" %>
    </div>
  <% else %>
    <div class="space-y-4">
      <% @jobs.each do |job| %>
        <div class="bg-white rounded-lg shadow p-6 border-l-4 <%= job_status_border_class(job.status) %>">
          <div class="flex justify-between items-start mb-3">
            <div>
              <h2 class="text-xl font-semibold text-gray-900"><%= job.title %></h2>
              <p class="text-gray-600"><%= job.location %> / <%= job.job_type %></p>
            </div>
            <span class="px-3 py-1 rounded-full text-sm font-medium <%= job_status_class(job.status) %>">
              <%= job_status_label(job.status) %>
            </span>
          </div>

          <div class="flex items-center gap-4 text-sm text-gray-500 mb-4">
            <% if job.salary_min.present? || job.salary_max.present? %>
              <span>
                💰 <%= number_with_delimiter(job.salary_min) %>〜<%= number_with_delimiter(job.salary_max) %>円
              </span>
            <% end %>
            <% if job.internship_available? %>
              <span class="bg-orange-100 text-orange-700 px-2 py-1 rounded">🎓 実習可</span>
            <% end %>
          </div>

          <div class="flex justify-end gap-2">
            <%= link_to "編集", edit_company_job_path(job),
                class: "text-teal-600 hover:text-teal-800 font-medium" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="mt-8">
    <%= link_to "← ダッシュボードに戻る", company_dashboard_path,
        class: "text-gray-600 hover:text-gray-800" %>
  </div>
</div>
