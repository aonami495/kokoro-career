<%= form_with model: [:company, job], local: true, class: "space-y-6" do |f| %>
  <% if job.errors.any? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
      <h3 class="font-bold mb-2">入力エラーがあります</h3>
      <ul class="list-disc list-inside">
        <% job.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-lg shadow p-6">
    <h2 class="text-xl font-semibold mb-4 border-b pb-2">基本情報</h2>

    <div class="space-y-4">
      <div>
        <%= f.label :title, "求人タイトル", class: "block font-semibold text-gray-700 mb-1" %>
        <%= f.text_field :title, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-teal-500 focus:border-teal-500", placeholder: "例: 一般事務スタッフ" %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= f.label :job_type, "雇用形態", class: "block font-semibold text-gray-700 mb-1" %>
          <%= f.select :job_type, Job::JOB_TYPE_OPTIONS, { include_blank: "選択してください" }, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-teal-500 focus:border-teal-500" %>
        </div>

        <div>
          <%= f.label :location, "勤務地", class: "block font-semibold text-gray-700 mb-1" %>
          <%= f.text_field :location, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-teal-500 focus:border-teal-500", placeholder: "例: 東京都渋谷区" %>
        </div>
      </div>

      <div>
        <%= f.label :description, "業務内容", class: "block font-semibold text-gray-700 mb-1" %>
        <%= f.text_area :description, rows: 6, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-teal-500 focus:border-teal-500", placeholder: "仕事内容を詳しく記載してください" %>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <h2 class="text-xl font-semibold mb-4 border-b pb-2">給与・条件</h2>

    <div class="space-y-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= f.label :salary_min, "給与（下限）", class: "block font-semibold text-gray-700 mb-1" %>
          <div class="flex items-center">
            <%= f.number_field :salary_min, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-teal-500 focus:border-teal-500", placeholder: "180000" %>
            <span class="ml-2 text-gray-600">円</span>
          </div>
        </div>

        <div>
          <%= f.label :salary_max, "給与（上限）", class: "block font-semibold text-gray-700 mb-1" %>
          <div class="flex items-center">
            <%= f.number_field :salary_max, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-teal-500 focus:border-teal-500", placeholder: "250000" %>
            <span class="ml-2 text-gray-600">円</span>
          </div>
        </div>
      </div>

      <div class="flex items-center p-4 bg-orange-50 rounded-lg border border-orange-200">
        <%= f.check_box :internship_available, class: "mr-3 text-orange-600 focus:ring-orange-500 h-5 w-5" %>
        <%= f.label :internship_available, class: "font-medium text-gray-800" do %>
          <span class="text-orange-700">🎓 体験実習を受け入れる</span>
          <p class="text-sm text-gray-600 font-normal mt-1">チェックすると、求職者が1〜2週間の職場体験実習に応募できるようになります。</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <h2 class="text-xl font-semibold mb-4 border-b pb-2">公開設定</h2>

    <div>
      <%= f.label :status, "ステータス", class: "block font-semibold text-gray-700 mb-1" %>
      <%= f.select :status, job_status_options_for_select, {}, class: "w-full md:w-1/2 px-4 py-2 border border-gray-300 rounded-lg focus:ring-teal-500 focus:border-teal-500" %>
      <p class="text-sm text-gray-500 mt-1">「公開中」にすると求職者に表示されます。</p>
    </div>
  </div>

  <div class="flex justify-between sticky bottom-4">
    <%= link_to "キャンセル", company_jobs_path,
        class: "bg-gray-200 text-gray-700 px-6 py-3 rounded-lg hover:bg-gray-300 text-lg font-semibold" %>
    <%= f.submit job.persisted? ? "更新する" : "作成する",
        class: "bg-teal-600 text-white px-8 py-3 rounded-lg hover:bg-teal-700 text-lg font-semibold shadow-lg cursor-pointer" %>
  </div>
<% end %>
